name: Gemini Deep Code Reviewer
on:
  workflow_dispatch:
  push:
    branches: [ main, develop ]

jobs:
  deep-review:
    runs-on: ubuntu-latest
    permissions:
      contents: write
    steps:
      - name: Checkout Code
        uses: actions/checkout@v4

      - name: Prepare Code File
        run: |
          # 将所有代码汇总到一个临时文件中，带上行号和文件名
          find . -maxdepth 5 -not -path '*/.*' -not -path '*/node_modules/*' -type f \( -name "*.html" -o -name "*.js" -o -name "*.css" -o -name "*.vue" \) | xargs -I {} sh -c 'echo "FILE: {}"; cat -n {}; echo "\n---"' > temp_code_for_ai.txt

      - name: Gemini Multi-File Review
        run: |
          # 1. 使用 1.5-flash 构造请求，它对免费用户最友好
          jq -n \
            --rawfile code_content temp_code_for_ai.txt \
            --arg prompt "你现在是一位资深的 Full Stack 工程师。请审查以下代码。要求：1. 找出潜在的 Bug、性能问题或不规范的写法。2. 必须指明具体的文件名和行号。3. 使用中英双语输出报告。4. 格式：Markdown 表格。代码如下：\n" \
            '{contents: [{parts: [{text: ($prompt + $code_content)}]}]}' > request.json

          # 2. 调用 1.5-flash 接口
          curl "https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent?key=${{ secrets.GEMINI_API_KEY }}" \
              -H 'Content-Type: application/json' \
              -X POST \
              -d @request.json > response.json

          # 3. 检查结果
          if jq -e '.candidates[0].content.parts[0].text' response.json > /dev/null; then
            jq -r '.candidates[0].content.parts[0].text' response.json > AI_Code_Review.md
            echo "✅ 审计报告已生成！"
          else
            echo "❌ 还是报错了？看下面日志："
            cat response.json
            exit 1
          fi

      - name: Commit Review Report
        run: |
          git config --local user.email "github-actions[bot]@users.noreply.github.com"
          git config --local user.name "github-actions[bot]"
          # 删除临时文件，不推送到仓库
          rm temp_code_for_ai.txt request.json response.json || true
          git add AI_Code_Review.md
          git commit -m "docs: Gemini Deep Code Review Report" || echo "No issues found"
          git push
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
